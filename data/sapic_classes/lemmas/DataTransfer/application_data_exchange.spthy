/* Lemmas for class `application_data_exchange` (data/sapic_classes/classes/2) DataTransfer/application_data_exchange.spthy). */

lemma executable:
  exists-trace
  "Ex mC mS #i #j #k #l.
       Send('Client', 'Server', mC) @ #i
     & Recv('Server', 'Client', mC) @ #j
     & Send('Server', 'Client', mS) @ #k
     & Recv('Client', 'Server', mS) @ #l
     & #i < #j
     & #j < #k
     & #k < #l"
