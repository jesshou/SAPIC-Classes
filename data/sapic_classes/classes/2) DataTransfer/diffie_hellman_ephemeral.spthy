theory diffie_hellman_ephemeral
begin

/* Ephemeral (fresh per-session) Diffie-Hellman key exchange - forward secrecy. */

builtins: diffie-hellman

let Client() =
    new eKc;                            // ephemeral secret exponent, generated fresh each run
    let ePKc = 'g'^eKc in               // Client's ephemeral public share
    event ClientSentGX(ePKc);
    out(ePKc);
    in(ePKs);
    event ClientRecvGY(ePKs);
    let dhZ = ePKs^eKc in                // shared secret = g^(eKc*eKs)
    event SessKey('Client', ePKc, ePKs, dhZ)  // feeds keys_match lemma

let Server() =
    new eKs;                            // ephemeral secret exponent, generated fresh each run
    let ePKs = 'g'^eKs in               // Server's ephemeral public share
    event ServerSentGY(ePKs);
    out(ePKs);
    in(ePKc);
    event ServerRecvGX(ePKc);
    let dhZ = ePKc^eKs in                // shared secret = g^(eKc*eKs)
    event SessKey('Server', ePKc, ePKs, dhZ)  // feeds keys_match lemma

process:
( !Client() | !Server() )

#include "../../lemmas/DataTransfer/diffie_hellman_ephemeral.spthy"

end
