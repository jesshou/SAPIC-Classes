theory diffie_hellman_static
begin

builtins: diffie-hellman

/* Static (long-term, reused) Diffie-Hellman key exchange - no forward
   secrecy, contrast with diffie_hellman_ephemeral.spthy. */

let Server =
    new skS;                       // long-term static secret exponent
    let pkS = 'g'^skS in
    out(pkS);                      // publish static public key
    !(
        in(pkC);                   // receive client's static public key
        let k = pkC^skS in         // k = g^(skC*skS)
        event ServerKey(pkS, pkC, k)
    )

let Client =
    new skC;                       // long-term static secret exponent
    let pkC = 'g'^skC in
    out(pkC);                      // publish static public key
    !(
        in(pkS);                   // receive server's static public key
        let k = pkS^skC in         // k = g^(skS*skC)
        event ClientKey(pkC, pkS, k)
    )

process:
    ( !Server | !Client )


lemma key_agreement_exists:
exists-trace
"Ex pkS pkC k #i #j.
    ServerKey(pkS, pkC, k) @ i  & ClientKey(pkC, pkS, k) @ j"

end
