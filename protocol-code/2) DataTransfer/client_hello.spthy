theory ClientHello
begin

/* ===== Client ===== */
let Client =
    new cr;                                  // client random (nonce)
    event Create_ClientHello(cr);            // mark creation of the Client Hello
    out(c, cr);            // send ClientHello
    

/* ===== Server ===== */
let Server =
    in(c, cr);              // receive the Client Hello
    event Receive_ClientHello(cr);
    

/* ===== Main process ===== */
process:
      ( !Client | !Server )

end
