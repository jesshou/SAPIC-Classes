theory server_hello
begin

/* Server sends a ServerHello (a fresh random); Client receives it. */

let Server =
    new sr;                          // server random (nonce)
    event Create_ServerHello(sr);    // mark creation of the Server Hello
    out(sr)

let Client =
    in(x);
    event ClientReceivedHello(x)     // record receipt for exists_ServerHello lemma

process:
    ( !Server ) | ( !Client )

lemma exists_ServerHello:
exists-trace
  " Ex x #i. ClientReceivedHello(x) @ i "

end
