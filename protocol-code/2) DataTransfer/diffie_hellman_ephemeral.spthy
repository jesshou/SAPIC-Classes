theory diffie_hellman_ephemeral
begin

/* Ephemeral (fresh per-session) Diffie-Hellman key exchange - forward secrecy. */

builtins: diffie-hellman

let Client() =
    new x;                            // ephemeral secret exponent, generated fresh each run
    let gx = 'g'^x in                 // Client's ephemeral public share
    event ClientSentGX(gx);
    out(gx);
    in(gy);
    event ClientRecvGY(gy);
    let k = gy^x in                   // shared secret = g^(x*y)
    event SessKey('Client', gx, gy, k)  // feeds keys_match lemma

let Server() =
    new y;                            // ephemeral secret exponent, generated fresh each run
    let gy = 'g'^y in                 // Server's ephemeral public share
    event ServerSentGY(gy);
    out(gy);
    in(gx);
    event ServerRecvGX(gx);
    let k = gx^y in                   // shared secret = g^(x*y)
    event SessKey('Server', gx, gy, k)  // feeds keys_match lemma

process:
( !Client() | !Server() )

lemma server_received_client_key:
  exists-trace
  "Ex gx #i #j.
      ServerRecvGX(gx) @ #i
      & ClientSentGX(gx) @ #j
      & #j < #i"

lemma client_received_server_key:
  exists-trace
  "Ex gy #i #j.
      ClientRecvGY(gy) @ #i
      & ServerSentGY(gy) @ #j
      & #j < #i"

lemma keys_match:
  "All gx gy k1 k2 #i #j.
      SessKey('Client', gx, gy, k1) @ #i &
      SessKey('Server', gx, gy, k2) @ #j
      ==> k1 = k2"

end