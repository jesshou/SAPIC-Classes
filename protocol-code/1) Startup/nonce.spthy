theory nonce
begin

/* ===== Client ===== */
let Client() =
    new n;                    // fresh, unpredictable nonce - proves freshness / prevents replay
    event ClientNonce(n);    
    0
    // NOTE: placement of `new n` matters - see "general_SAPIC+_instruction".

process:
( !Client() )

lemma nonce_executable:
    exists-trace
    "Ex n #i. ClientNonce(n) @ i"

end
