theory setup
begin

/*
 * SECTION: Start-up
 *
 * Bare-minimum: just Client, Server, and the top-level process block.
 */

let Client(~id) =
    event ClientInit(~id);
    0 

let Server(~id) =
    event ServerInit(~id);
    0 

process:
new ~clientId;
new ~serverId;
( !Client(~clientId) | !Server(~serverId) )

lemma setup_executable:
    exists-trace
    "Ex id #i. ClientInit(id) @ i"

end
