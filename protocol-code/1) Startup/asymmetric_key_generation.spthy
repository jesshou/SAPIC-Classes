theory asymmetric_key_generation
begin

builtins: asymmetric-encryption

let Client() =
    new ~ltkA;
    let pkA = pk(~ltkA) in
    event ClientInit(pkA);
    0

let Server() =
    new ~ltkB;
    let pkB = pk(~ltkB) in
    event ServerInit(pkB);
    0

process:
( !Client() | !Server() )

lemma setup_executable:
    exists-trace
    "Ex pk #i. ClientInit(pk) @ i"

lemma server_setup_executable:
    exists-trace
    "Ex pk #i. ServerInit(pk) @ i"

end
